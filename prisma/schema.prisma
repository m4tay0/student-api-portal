generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model announcements {
  id         Int       @id @default(autoincrement())
  course_id  Int?
  title      String?   @db.VarChar(200)
  content    String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  courses    courses?  @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model assignments {
  id          Int           @id @default(autoincrement())
  course_id   Int?
  title       String?       @db.VarChar(200)
  due_date    DateTime?     @db.Timestamp(6)
  description String?
  courses     courses?      @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  submissions submissions[]
}

model courses {
  id            Int             @id @default(autoincrement())
  code          String?         @db.VarChar(10)
  name          String?         @db.VarChar(100)
  credits       Int?
  instructor    String?         @db.VarChar(100)
  day_of_week   String?         @db.VarChar(20)
  start_time    String?         @db.VarChar(10)
  end_time      String?         @db.VarChar(10)
  room          String?         @db.VarChar(50)
  announcements announcements[]
  assignments   assignments[]
  grades        grades[]
}

model grades {
  id           Int       @id @default(autoincrement())
  student_id   Int?
  course_id    Int?
  midterm      Decimal?  @db.Decimal(5, 2)
  final        Decimal?  @db.Decimal(5, 2)
  letter_grade String?   @db.VarChar(2)
  courses      courses?  @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students     students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model students {
  id                Int                 @id @default(autoincrement())
  student_no        String?             @unique @db.VarChar(10)
  first_name        String?             @db.VarChar(50)
  last_name         String?             @db.VarChar(50)
  department        String?             @db.VarChar(100)
  email             String?             @db.VarChar(100)
  passwordHash      String?             @map("password_hash")
  advisor_id        Int?
  advisors          advisors?           @relation(fields: [advisor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  grades            grades[]
  submissions       submissions[]
  appointments      appointments[]
  messages          messages[]
  document_requests document_requests[]
  notifications     notifications[]
}

model submissions {
  id            Int          @id @default(autoincrement())
  assignment_id Int?
  student_id    Int?
  submitted_at  DateTime?    @db.Timestamp(6)
  file_url      String?
  status        String?      @default("pending") @db.VarChar(20)
  assignments   assignments? @relation(fields: [assignment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students      students?    @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model advisors {
  id           Int            @id @default(autoincrement())
  first_name   String?        @db.VarChar(50)
  last_name    String?        @db.VarChar(50)
  title        String?        @db.VarChar(100)
  email        String?        @db.VarChar(100)
  office       String?        @db.VarChar(50)
  office_hours String?        @db.VarChar(100)
  students     students[]
  appointments appointments[]
  messages     messages[]
}

model appointments {
  id               Int       @id @default(autoincrement())
  student_id       Int?
  advisor_id       Int?
  appointment_date DateTime? @db.Timestamp(6)
  status           String?   @default("approved") @db.VarChar(20)
  notes            String?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  students         students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  advisors         advisors? @relation(fields: [advisor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model messages {
  id          Int       @id @default(autoincrement())
  student_id  Int?
  advisor_id  Int?
  sender_type String?   @db.VarChar(20)
  content     String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  students    students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  advisors    advisors? @relation(fields: [advisor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model document_requests {
  id                Int       @id @default(autoincrement())
  student_id        Int?
  document_type     String?   @db.VarChar(50)
  verification_code String?   @unique @db.VarChar(100)
  status            String?   @default("ready") @db.VarChar(20)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  students          students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model notifications {
  id         Int       @id @default(autoincrement())
  student_id Int?
  title      String?   @db.VarChar(150)
  message    String?
  type       String?   @db.VarChar(50)
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  students   students? @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
